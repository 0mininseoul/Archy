# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=replace-with-a-random-16-plus-char-string

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Groq API (STT - Whisper Large V3)
GROQ_API_KEY=your-groq-api-key
# Optional STT key routing (active recorder users)
# - active users >= 3: use GROQ_API_KEY_TIER_2
# - active users >= 5: use GROQ_API_KEY_TIER_3
# Optional ASPD-aware routing (rolling 24h aggregate)
# - switch away from a key once projected usage crosses risk threshold
GROQ_API_KEY_TIER_2=your-second-groq-api-key
GROQ_API_KEY_TIER_3=your-third-groq-api-key
GROQ_AUDIO_SECONDS_DAILY_LIMIT=28800
GROQ_AUDIO_SECONDS_HOURLY_LIMIT=7200
GROQ_AUDIO_SECONDS_DAILY_RISK_THRESHOLD_RATIO=0.9
GROQ_AUDIO_SECONDS_HOURLY_RISK_THRESHOLD_RATIO=0.9
GROQ_AUDIO_SECONDS_DAILY_FIXED_BUFFER_SECONDS=300
GROQ_AUDIO_SECONDS_DAILY_BUFFER_PER_ACTIVE_RECORDER_SECONDS=40
GROQ_AUDIO_SECONDS_ROLLING_WINDOW_HOURS=24
GROQ_AUDIO_SECONDS_BUCKET_MINUTES=5
GROQ_ASPD_RATE_LIMIT_COOLDOWN_MINUTES=60

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=https://your-app.vercel.app/api/auth/notion/callback

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
# Runtime derives the actual callback from NEXT_PUBLIC_APP_URL.
# Keep this in sync only if you use it as a provider-console reference value.
SLACK_REDIRECT_URI=https://your-app.vercel.app/api/auth/slack/callback

# Google (Docs/Drive 연동)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# Push 알림 (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Analytics (Amplitude)
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key

# Monitoring (Sentry)
# Runtime DSN: client uses NEXT_PUBLIC_SENTRY_DSN, server can use SENTRY_DSN or fall back to NEXT_PUBLIC_SENTRY_DSN
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0000000000000000.ingest.us.sentry.io/0000000000000000
SENTRY_DSN=https://examplePublicKey@o0000000000000000.ingest.us.sentry.io/0000000000000000
# Build-time source map upload
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token
# Optional runtime label override (defaults to VERCEL_ENV / NODE_ENV)
SENTRY_ENVIRONMENT=development

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Gemini (Archy Ops Agent)
GEMINI_API_KEY=your-gemini-api-key
# Optional: generic Gemini HTTP timeout/retry
GEMINI_REQUEST_TIMEOUT_MS=90000
GEMINI_REQUEST_MAX_RETRIES=1
GEMINI_REQUEST_RETRY_BASE_MS=1500
GEMINI_REQUEST_RETRY_CAP_MS=12000
# Optional: 전략 리뷰 프로파일 재시도 오케스트레이션(권장)
GEMINI_STRATEGIC_REVIEW_SLA_MS=300000
GEMINI_STRATEGIC_REVIEW_TEMPERATURE=1.0
GEMINI_STRATEGIC_REVIEW_PRO_MAX_OUTPUT_TOKENS=5120
GEMINI_STRATEGIC_REVIEW_PRO_RETRY_MAX_OUTPUT_TOKENS=6144
GEMINI_STRATEGIC_REVIEW_FLASH_MAX_OUTPUT_TOKENS=2048
GEMINI_STRATEGIC_REVIEW_PRO_TIMEOUT_MS=90000
GEMINI_STRATEGIC_REVIEW_FLASH_TIMEOUT_MS=60000
GEMINI_STRATEGIC_REVIEW_FORCE_THINKING_LEVEL_PRO=high
GEMINI_STRATEGIC_REVIEW_FORCE_THINKING_LEVEL_FLASH=high
GEMINI_STRATEGIC_REVIEW_MIN_CANDIDATE_TOKENS=180
GEMINI_STRATEGIC_REVIEW_MAX_RETRIES=0

# Discord Bot (Railway)
DISCORD_BOT_TOKEN=your-discord-bot-token
# Optional alias also supported by bot runtime: DISCORD_TOKEN
DISCORD_GUILD_ID=your-discord-server-id
# Optional alias: DISCORD_SERVER_ID
DISCORD_DAILY_CHANNEL_ID=your-daily-report-channel-id
# Optional alias: DISCORD_CHANNEL_ID
# Optional: comma-separated channel IDs for mention/chat responses
DISCORD_CHAT_CHANNEL_IDS=channel_id_1,channel_id_2
# Optional alias: DISCORD_CHANNEL_IDS
# Optional: cache TTL(seconds) for mention-based advisory dry-run snapshot
ARCHY_CHAT_REPORT_CACHE_SECONDS=300
# Optional: cache TTL(seconds) for live work progress context in mention replies
ARCHY_WORK_CONTEXT_CACHE_SECONDS=300
# Optional: Supabase-backed conversation memory controls
ARCHY_MEMORY_ENABLED=true
ARCHY_MEMORY_RECENT_TURNS=12
ARCHY_MEMORY_SUMMARY_MIN_TURNS=24
ARCHY_MEMORY_SUMMARY_KEEP_RECENT_TURNS=10
ARCHY_MEMORY_SUMMARY_MIN_INTERVAL_MINUTES=180
# Optional: mention 기반 툴 실행 최대 호출 수
ARCHY_TOOL_MAX_CALLS=5
# Optional: tool planner/summary timeout and retries
ARCHY_TOOL_PLANNER_TIMEOUT_MS=45000
ARCHY_TOOL_PLANNER_MAX_RETRIES=1
ARCHY_TOOL_SUMMARY_TIMEOUT_MS=30000
ARCHY_TOOL_SUMMARY_MAX_RETRIES=1

# Google Sheets (Service Account for Archy Ops Agent)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\"
ARCHY_USER_SHEET_ID=1f2bD-9h46UMPtbw836-45bd73__FeiKxEaPdcCUue20
ARCHY_USER_SHEET_TAB_NAME=유저 데이터 최종
# Optional: true(기본)면 시트 누락 유저 전체 백필, false면 당일 가입자만 동기화
ARCHY_SHEET_SYNC_ALL_USERS=true

# Notion (Internal Integration for Archy Ops Agent)
NOTION_INTERNAL_INTEGRATION_TOKEN=secret_xxx
# Required: Archy 유저 데이터 업데이트 DB(or data source) ID
NOTION_USER_METRICS_DATABASE_ID=your-notion-database-or-data-source-id
# Required for dated task auto-create (and recommended for 업무 진행상황 추적)
NOTION_WORK_DB_DATA_SOURCE_ID=26abd55c-4778-80a6-b4c3-000b1976e9d8
# Optional: Ascentum 페이지 ID(or URL). 설정 시 최근 편집 블록 추적
NOTION_ASCENTUM_PAGE_ID=your-ascentum-page-id-or-url
# Optional defaults for mention-based notion actions
NOTION_DEFAULT_PARENT_PAGE_ID=your-default-parent-page-id
NOTION_DEFAULT_DATA_SOURCE_ID=your-default-data-source-id
# Default main page for mention-based Notion page creation
ARCHY_NOTION_MAIN_PAGE_URL=https://www.notion.so/0-min/Archy-AI-2e9bd55c477880bda196c1fbf4f74ca7?source=copy_link
# Optional aliases (comma-separated) that refer to the main Notion page
ARCHY_NOTION_MAIN_PAGE_ALIASES=아키 페이지,archy 페이지,메인 페이지

# Amplitude (Signup conversion chart fetch)
AMPLITUDE_DASHBOARD_REST_API_KEY=your-amplitude-dashboard-api-key
AMPLITUDE_DASHBOARD_REST_SECRET=your-amplitude-dashboard-rest-secret
AMPLITUDE_SIGNUP_CONVERSION_CHART_ID=your-chart-id
# Optional overrides
# AMPLITUDE_DASHBOARD_API_BASE_URL=https://amplitude.com
# AMPLITUDE_SIGNUP_CONVERSION_CHART_API_URL=https://your-own-proxy/chart
# AMPLITUDE_SIGNUP_CONVERSION_API_BEARER=token
# AMPLITUDE_SIGNUP_CONVERSION_STATIC_RATE=0.123

# Web research (optional)
# - If omitted, agent falls back to DuckDuckGo HTML search.
TAVILY_API_KEY=tvly-xxx

# Polar (Payment)
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_SUCCESS_URL=https://your-app.vercel.app/dashboard?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=your-pro-product-id
NEXT_PUBLIC_POLAR_FREE_PRODUCT_ID=your-free-product-id
