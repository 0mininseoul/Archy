# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Groq API (STT - Whisper Large V3)
GROQ_API_KEY=your-groq-api-key
# Optional STT key routing (active recorder users)
# - active users >= 3: use GROQ_API_KEY_TIER_2
# - active users >= 5: use GROQ_API_KEY_TIER_3
GROQ_API_KEY_TIER_2=your-second-groq-api-key
GROQ_API_KEY_TIER_3=your-third-groq-api-key

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=https://your-app.vercel.app/api/auth/notion/callback

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=https://your-app.vercel.app/api/auth/slack/callback

# Google (Docs/Drive 연동)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# Push 알림 (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Analytics (Amplitude)
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Gemini (Discord Assistant Agent)
GEMINI_API_KEY=your-gemini-api-key

# Discord Bot (Railway)
DISCORD_BOT_TOKEN=your-discord-bot-token
# Optional alias also supported by bot runtime: DISCORD_TOKEN
DISCORD_GUILD_ID=your-discord-server-id
# Optional alias: DISCORD_SERVER_ID
DISCORD_DAILY_CHANNEL_ID=your-daily-report-channel-id
# Optional alias: DISCORD_CHANNEL_ID
# Optional: comma-separated channel IDs for mention/chat responses
DISCORD_CHAT_CHANNEL_IDS=channel_id_1,channel_id_2
# Optional alias: DISCORD_CHANNEL_IDS
# Optional: cache TTL(seconds) for mention-based advisory dry-run snapshot
ARCHY_CHAT_REPORT_CACHE_SECONDS=300
# Optional: Supabase-backed conversation memory controls
ARCHY_MEMORY_ENABLED=true
ARCHY_MEMORY_RECENT_TURNS=12
ARCHY_MEMORY_SUMMARY_MIN_TURNS=24
ARCHY_MEMORY_SUMMARY_KEEP_RECENT_TURNS=10
ARCHY_MEMORY_SUMMARY_MIN_INTERVAL_MINUTES=180
# Optional: mention 기반 툴 실행 최대 호출 수
ARCHY_TOOL_MAX_CALLS=5

# Google Sheets (Service Account for Assistant Agent)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\"
ARCHY_USER_SHEET_ID=1f2bD-9h46UMPtbw836-45bd73__FeiKxEaPdcCUue20
ARCHY_USER_SHEET_TAB_NAME=유저 데이터 최종

# Notion (Internal Integration for Assistant Agent)
NOTION_INTERNAL_INTEGRATION_TOKEN=secret_xxx
NOTION_USER_METRICS_DATABASE_ID=317bd55c-4778-80bb-9ae8-d597501f7dbe
# Optional defaults for mention-based notion actions
NOTION_DEFAULT_PARENT_PAGE_ID=your-default-parent-page-id
NOTION_DEFAULT_DATA_SOURCE_ID=your-default-data-source-id

# Amplitude (Signup conversion chart fetch)
AMPLITUDE_DASHBOARD_REST_API_KEY=your-amplitude-dashboard-api-key
AMPLITUDE_DASHBOARD_REST_SECRET=your-amplitude-dashboard-rest-secret
AMPLITUDE_SIGNUP_CONVERSION_CHART_ID=your-chart-id
# Optional overrides
# AMPLITUDE_DASHBOARD_API_BASE_URL=https://amplitude.com
# AMPLITUDE_SIGNUP_CONVERSION_CHART_API_URL=https://your-own-proxy/chart
# AMPLITUDE_SIGNUP_CONVERSION_API_BEARER=token
# AMPLITUDE_SIGNUP_CONVERSION_STATIC_RATE=0.123

# Web research (optional)
# - If omitted, agent falls back to DuckDuckGo HTML search.
TAVILY_API_KEY=tvly-xxx

# Polar (Payment)
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_SUCCESS_URL=https://your-app.vercel.app/dashboard?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=your-pro-product-id
NEXT_PUBLIC_POLAR_FREE_PRODUCT_ID=your-free-product-id
